{
  "entities": {
    "cashier_session": {
      "title": "Cashier Session",
      "description": "Represents an active or closed cashier register session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "tenantId", "status"]
    },
    "history": {
      "title": "History",
      "description": "Historical log of system activities",
